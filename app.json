{
  "expo": {
    "name": "Multipurpose Fitness App",
    "slug": "multipurpose-fitness-app",
    "version": "1.0.0",
    "sdkVersion": "49.0.0",
    "platforms": ["ios", "android", "web"],
    "scheme": "multipurposefitness",
    "assetBundlePatterns": ["assets/**/*", "public/3D Animation Videos/**/*"],
    "icon": "./assets/app-icon.png",
    "splash": {
      "image": "./assets/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.prakharanand.fitnesstracker",
      "config": {
        "usesNonExemptEncryption": false
      },
      "permissions": ["CAMERA", "PHOTO_LIBRARY", "CONTACTS"]
    },
    "android": {
      "package": "com.prakharanand.fitnesstracker",
      "versionCode": 1,
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/app-icon.png"
    }
  }
}
